# Server (SSH key auth required — run ssh-copy-id first)
SERVER_IP=123.45.67.89
SSH_USER=root

# Domain — uses sslip.io (auto-DNS from IP, no domain needed)
# BASE_DOMAIN will be set automatically to: SERVER_IP.sslip.io
# Previews: feature-name.preview.SERVER_IP.sslip.io
# n8n:      n8n.preview.SERVER_IP.sslip.io

# MySQL
# IMPORTANT: Do NOT use $ in the password — it causes issues with bash variable
# expansion and Docker Compose interpolation. Stick to alphanumeric + : @ ! % ^ & * _
MYSQL_ROOT_PASSWORD=generate-a-strong-password-without-dollar-signs

# Craft CMS
# Security key is auto-generated if left empty
CRAFT_SECURITY_KEY=
# Admin account for fresh installs (no database dump)
CRAFT_ADMIN_EMAIL=admin@example.com
CRAFT_ADMIN_PASSWORD=change-me

# Git
# Public repos: use HTTPS URL (no deploy key needed)
GIT_REPO_URL=https://github.com/org/repo.git
# Private repos: use SSH URL + add deploy key (see CLAUDE.md Phase 10)
# GIT_REPO_URL=git@github.com:org/repo.git
GIT_HOST=github.com
